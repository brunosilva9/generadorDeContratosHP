# Caddy listens on the port Cloud Run injects (PORT env var, defaults to 8080),
# adds permissive CORS headers, and proxies everything else to Gotenberg.

:{$PORT} {
    # Preflight handling: respond 204 with CORS headers, no proxy needed.
    @preflight method OPTIONS
    handle @preflight {
        header {
            Access-Control-Allow-Origin "*"
            Access-Control-Allow-Methods "GET, POST, OPTIONS"
            Access-Control-Allow-Headers "Content-Type, Accept"
            Access-Control-Max-Age "86400"
        }
        respond 204
    }

    # All other requests: forward to Gotenberg on localhost:3000.
    handle {
        header {
            Access-Control-Allow-Origin "*"
            Access-Control-Expose-Headers "Content-Disposition, Content-Type"
        }
        reverse_proxy 127.0.0.1:3000 {
            # Conversions can take a while for big merges.
            transport http {
                response_header_timeout 120s
                read_timeout 120s
            }
        }
    }

    log {
        output stdout
        format console
    }
}
