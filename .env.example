# URL of the LibreOffice/Gotenberg PDF conversion service.
# Empty / unset = the frontend falls back to in-browser conversion
# (html2canvas + jsPDF), which is lossy on column layouts and DrawingML shapes.
#
# Local dev: docker compose -f server/docker-compose.yml up --build
#   then: VITE_PDF_API_URL=http://localhost:8080
#
# Production: deploy server/ to Cloud Run (see server/README.md), then put
# the resulting URL in this var (or in repo Variables for the CI build).
VITE_PDF_API_URL=
